# Telegram bot token from BotFather.
TELEGRAM_TOKEN=

# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Options: true, false. Enables debug snippets of P2P order descriptions in logs.
P2P_LOG_DESCRIPTION_SNIPPETS=false

# Optional Telegram user IDs with SUPER_ADMIN role. Comma-separated.
# Example: SUPER_ADMIN_TELEGRAM_IDS=123456789,987654321
SUPER_ADMIN_TELEGRAM_IDS=

# PostgreSQL connection parts used to build DB_URL.
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=p2p_bot

# Optional full database URL. Keep postgresql+asyncpg for async SQLAlchemy.
# Example: DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/p2p_bot
DATABASE_URL=

# OpenAI Responses API settings for GPT description checks.
OPENAI_API_KEY=
OPENAI_P2P_MODEL=gpt-5-nano
OPENAI_P2P_CLASSIFIER_TIMEOUT=60

# Optional vector store IDs for file_search. Prefer plural for multiple stores.
# Examples:
# OPENAI_VECTOR_STORE_ID=vs_...
# OPENAI_VECTOR_STORE_IDS=vs_...,vs_...
OPENAI_VECTOR_STORE_ID=
OPENAI_VECTOR_STORE_IDS=
OPENAI_FILE_SEARCH_MAX_RESULTS=3

# Optional Telegram custom emoji IDs for exchange buttons.
BINANCE_ICON_CUSTOM_EMOJI_ID=
OKX_ICON_CUSTOM_EMOJI_ID=
