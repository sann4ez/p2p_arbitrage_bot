# Telegram bot token from BotFather.
TELEGRAM_TOKEN=

# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Options: true, false. Enables debug snippets of P2P order descriptions in logs.
P2P_LOG_DESCRIPTION_SNIPPETS=false

# Optional Telegram user IDs with SUPER_ADMIN role. Comma-separated.
# Example: SUPER_ADMIN_TELEGRAM_IDS=123456789,987654321
SUPER_ADMIN_TELEGRAM_IDS=

# PostgreSQL connection parts used to build DB_URL.
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=p2p_bot

# Optional full database URL. Keep postgresql+asyncpg for async SQLAlchemy.
# Example: DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/p2p_bot
DATABASE_URL=

# Create missing database tables and seed base roles/reference data on bot startup.
# Keep enabled for Railway/first deploys. Set to false only if you run migrations manually.
DB_AUTO_CREATE_TABLES=true
DB_AUTO_SEED_REFERENCE_DATA=true

# OpenAI Responses API settings for GPT description checks.
OPENAI_API_KEY=
OPENAI_P2P_MODEL=gpt-5-nano
OPENAI_P2P_CLASSIFIER_TIMEOUT=60

# Split GPT classification into smaller parallel batches.
# Lower concurrency is gentler; higher concurrency is faster but can hit rate limits.
OPENAI_P2P_CLASSIFIER_BATCH_SIZE=10
OPENAI_P2P_CLASSIFIER_CONCURRENCY=3
OPENAI_P2P_CLASSIFICATION_CACHE_TTL_SECONDS=600

# Optional vector store IDs for file_search. Prefer plural for multiple stores.
# Examples:
# OPENAI_VECTOR_STORE_ID=vs_...
# OPENAI_VECTOR_STORE_IDS=vs_...,vs_...
OPENAI_VECTOR_STORE_ID=
OPENAI_VECTOR_STORE_IDS=
OPENAI_FILE_SEARCH_MAX_RESULTS=3

# Optional Telegram custom emoji IDs for exchange buttons.
BINANCE_ICON_CUSTOM_EMOJI_ID=
OKX_ICON_CUSTOM_EMOJI_ID=

# P2P request protection for local/home IP usage.
# User cooldown limits how often one Telegram user can request P2P data.
P2P_USER_COOLDOWN_SECONDS=8

# Global cooldown spaces real exchange requests from this bot process.
P2P_GLOBAL_COOLDOWN_SECONDS=2

# Cache exchange order lists so several users can reuse the same response.
P2P_CACHE_TTL_SECONDS=30

# Cache order detail/description requests a bit longer.
P2P_DETAILS_CACHE_TTL_SECONDS=90

# How many orders to show on one Telegram page.
P2P_ORDERS_PER_PAGE=3

# How long inline pagination sessions live in bot memory.
P2P_PAGINATION_TTL_SECONDS=600
